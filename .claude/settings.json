{
  "permissions": {
    "allow": [
      "Bash(python -c \":*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(rm -r tmp/*)",
      "Bash(rm -r captures/*)",
      "Bash(.venv/Scripts/python tools/*)",
      "Bash(.venv/Scripts/python -m pytest*)",
      "Bash(.venv/Scripts/python main.py*)",
      "Bash(.venv/Scripts/pytest*)",
      "Bash(python tools/*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git switch*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git remote*)",
      "Bash(git config --get*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch*)",
      "Bash(git pull --ff-only*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(wget *)",
      "Read(**/.env*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(**/.env*)",
      "Write(**/secrets/**)"
    ],
    "ask": [
      "Bash(mv *)",
      "Bash(curl *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git merge *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/md_to_html.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/check_sync.py\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "[System.Media.SystemSounds]::Exclamation.Play(); Start-Sleep -Milliseconds 700"
          }
        ]
      }
    ]
  }
}
